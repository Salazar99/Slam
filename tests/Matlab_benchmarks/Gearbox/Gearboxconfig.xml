<slam>
		<context name="Gear"> 
		<!--
		double EngineRPM;double Throttle;double Brake;double gear;double ImpellerTorque;double OutputTorque;double VehicleSpeed;double TransmissionRPM
		<numeric clustering="K,10Max,0.01WCSS,><,==,>=,<=" clsEffort = "0.1" exp="Brake" loc="dt"/>
	    -->
		<numeric clustering="K,5Max,0.01WCSS,><,==,>=,<=" clsEffort = "0.01" exp="EngineRPM" loc="dt"/>
		<numeric clustering="K,5Max,0.01WCSS,><,==,>=,<=" clsEffort = "0.01" exp="Throttle" loc="dt"/>
		<numeric clustering="K,5Max,0.01WCSS,><,==,>=,<=" clsEffort = "0.01" exp="ImpelTorque" loc="dt"/>
		<numeric clustering="K,5Max,0.01WCSS,><,==,>=,<=" clsEffort = "0.01" exp="OutTorque" loc="dt"/>
		<numeric clustering="K,5Max,0.01WCSS,><,==,>=,<=" clsEffort = "0.01" exp="VehiSpeed" loc="dt"/>
		<numeric clustering="K,5Max,0.01WCSS,><,==,>=,<=" clsEffort = "0.01" exp="TransRPM" loc="dt"/>
		<numeric clustering="K,5Max,0.01WCSS,==" clsEffort = "0.1" exp="gear" loc="c"/>

        <template dtLimits="3A,0.1E,100maxd,0mind" exp="G( ..F.. -> F[0,0]P0)" />

		<sort name="causality" exp="1-afct/traceLength"/>
		<sort name="support" exp="atct/traceLength"/>
	</context>

		<!--
		double EngineRPM;double Throttle;double Brake;double gear;double ImpellerTorque;double OutputTorque;double VehicleSpeed;double TransmissionRPM
		<numeric clustering="K,10Max,0.01WCSS,><,==,>=,<=" clsEffort = "0.01" exp="Brake" loc="dt"/>

	<context name="EngineSpeed"> 
		<numeric clustering="K,10Max,0.01WCSS,><,==,>=,<="  clsEffort = "0.01" exp="EngineRPM" loc="dt"/>
		<numeric clustering="K,10Max,0.01WCSS,><,==,>=,<=" clsEffort = "0.01" exp="Throttle" loc="dt"/>
		<numeric clustering="K,10Max,0.01WCSS,><,==,>=,<=" clsEffort = "0.01" exp="ImpelTorque" loc="dt"/>
		<numeric clustering="K,10Max,0.01WCSS,><,==,>=,<=" clsEffort = "0.01" exp="OutTorque" loc="dt"/>
		<numeric clustering="K,10Max,0.01WCSS,><,==,>=,<=" clsEffort = "0.01" exp="VehiSpeed" loc="c"/>
		<numeric clustering="K,10Max,0.01WCSS,><,==,>=,<=" clsEffort = "0.01" exp="TransRPM" loc="dt"/>
		<numeric clustering="K,10Max,0.01WCSS,==,>=,<=" clsEffort = "0.01" exp="gear" loc="dt"/>

        <template dtLimits="3A,0.1E,100maxd,0mind" exp="G( ..F.. -> F[0,0]P0)" />

		<sort name="causality" exp="1-afct/traceLength"/>
		<sort name="support" exp="atct/traceLength"/>
	</context>
	    -->
	  
	<context  name="check_gear">
        <template check='1' exp="G(F[0,0](((TransRPM >= 183.864) && (TransRPM <= 5566.53))) -> F[0,100](((gear >= 3) && (gear <= 4))))" />
	</context>


</slam>
